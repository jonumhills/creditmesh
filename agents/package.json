{
  "name": "@agentcredit/agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "agents:create":    "ts-node-dev --transpile-only src/scripts/createAgents.ts",
    "agents:fund":      "ts-node-dev --transpile-only src/scripts/fundAgents.ts",
    "agents:bootstrap": "ts-node-dev --transpile-only src/scripts/bootstrapAgents.ts",
    "agents:setscores": "ts-node-dev --transpile-only src/scripts/setDemoScores.ts",
    "agents:start":     "ts-node-dev --respawn --transpile-only src/orchestrator.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "ethers": "^6.13.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
